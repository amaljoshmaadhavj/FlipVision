# FlipVision .gitignore - Prevent sensitive data from being committed

# ==============================================================================
# Environment Variables & Secrets
# ==============================================================================
.env
.env.local
.env.*.local
.env.production
*.key
*.pem

# ==============================================================================
# Python
# ==============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt

# ==============================================================================
# Virtual Environments
# ==============================================================================
.venv
.env.venv
env.bak/
venv.bak/

# ==============================================================================
# IDEs and Editors
# ==============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-workspace
*.sublime-project
.project
.pydevproject
.settings/
*.iml
.c9/

# ==============================================================================
# Django
# ==============================================================================
db.sqlite3
db.sqlite3-journal
*.log
media/
staticfiles/
local_settings.py
/static/
/staticfiles/

# ==============================================================================
# Database Files
# ==============================================================================
*.db
*.sqlite
*.sqlite3
backup/
*.bak

# ==============================================================================
# Compiled Files
# ==============================================================================
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# ==============================================================================
# OS Generated Files
# ==============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.ini
*.cfg

# ==============================================================================
# Machine Learning Models (Optional - Large Files)
# ==============================================================================
# Uncomment if models are too large for git
# *.pt
# *.pth
# *.h5
# *.pkl
# *.joblib
# *.model

# ==============================================================================
# Notebooks
# ==============================================================================
.ipynb_checkpoints/
*.ipynb
.jupyter/

# ==============================================================================
# Coverage Reports
# ==============================================================================
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ==============================================================================
# Project Specific
# ==============================================================================
/uploads/
/temp/
/tmp/
*.tmp
*~.nib

# ==============================================================================
# Testing
# ==============================================================================
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# ==============================================================================
# Certificates & SSL
# ==============================================================================
*.crt
*.cer
*.pem
*.pfx
*.p12

# ==============================================================================
# Build Artifacts
# ==============================================================================
build/
dist/
*.egg-info/
*.eggs/

# ==============================================================================
# Dependency Lock Files (optional - comment out if you want to track them)
# ==============================================================================
# Pipfile.lock
# poetry.lock
# requirements.lock

# ==============================================================================
# Environment-specific files
# ==============================================================================
.env.development
.env.production
.env.testing
.env.staging

# ==============================================================================
# Docker
# ==============================================================================
.dockerignore
docker-compose.override.yml

# ==============================================================================
# CI/CD
# ==============================================================================
.github/workflows/secrets.yml
.gitlab-ci.yml.local

# ==============================================================================
# API Keys and Credentials (just in case)
# ==============================================================================
config/secrets/
credentials/
secrets/
tokens/
